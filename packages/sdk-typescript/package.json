{
  "name": "@headlessoracle/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Headless Oracle — Ed25519-signed market-state attestations for 28 global exchanges",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["headless-oracle", "market-state", "ed25519", "mcp", "x402", "trading", "agent"],
  "license": "MIT",
  "author": "LembaGang",
  "repository": {
    "type": "git",
    "url": "https://github.com/LembaGang/headless-oracle-v5",
    "directory": "packages/sdk-typescript"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
