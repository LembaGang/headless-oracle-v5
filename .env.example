# Headless Oracle V5 — Environment Variables
# Copy to .dev.vars for local development. Production values go in
# Cloudflare Secrets (wrangler secret put <NAME>).

# ─── Ed25519 Signing Keypair ─────────────────────────────────────────────────
# Hex-encoded. Generate with: node -e "const ed=require('@noble/ed25519');const k=ed.utils.randomPrivateKey();console.log(Buffer.from(k).toString('hex'))"
ED25519_PRIVATE_KEY=your-64-char-hex-private-key-here
ED25519_PUBLIC_KEY=your-64-char-hex-public-key-here

# ─── API Key Authentication ──────────────────────────────────────────────────
MASTER_API_KEY=your-master-api-key-here
BETA_API_KEYS=beta_key_1,beta_key_2

# ─── Supabase (key management database) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Paddle Billing ─────────────────────────────────────────────────────────
PADDLE_API_KEY=pdl_apikey_your-paddle-api-key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_your-webhook-secret
PADDLE_PRICE_ID=pri_your-default-price-id
PADDLE_PRICE_ID_BUILDER=pri_your-builder-price-id
PADDLE_PRICE_ID_PRO=pri_your-pro-price-id
PADDLE_PRICE_ID_PROTOCOL=pri_your-protocol-price-id
PADDLE_PRICE_ID_CREDITS=pri_your-credits-price-id

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ─── x402 Micropayments (Base mainnet) ───────────────────────────────────────
ORACLE_PAYMENT_ADDRESS=0xYourBaseMainnetWalletAddress

# ─── x402 Testnet (optional) ────────────────────────────────────────────────
# X402_ENABLED=true
# X402_TEST_WALLET=0xYourBaseSepoliaTestWallet

# ─── Coinbase CDP (x402 facilitator auth) ────────────────────────────────────
# CDP_API_KEY_NAME=organizations/xxx/apiKeys/yyy
# CDP_API_KEY_PRIVATE_KEY=base64-encoded-private-key

# ─── Real-time Halt Monitoring (optional) ────────────────────────────────────
# POLYGON_API_KEY=your-polygon-io-api-key
